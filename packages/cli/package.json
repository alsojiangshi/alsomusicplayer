{
  "name": "@music-player/cli",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "tsc",
    "compile:linux": "bun build --compile --target=bun-linux-x64-modern src/main.ts --outfile ../../dist/MusicPlayer-cli-linux",
    "compile:windows": "bun build --compile --target=bun-windows-x64-modern src/main.ts --outfile ../../dist/MusicPlayer-cli-windows"
  },
  "dependencies": {
    "@music-player/core": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3"
  }
}
