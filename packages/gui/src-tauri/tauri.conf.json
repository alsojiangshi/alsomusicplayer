{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlsoMusicPlayer",
  "version": "2.0.0",
  "identifier": "com.alsomusicplayer.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AlsoMusicPlayer",
        "width": 1380,
        "height": 920,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
