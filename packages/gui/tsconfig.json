{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": "..",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@core": ["../core/src/browser.ts"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "../core/src/browser.ts",
    "../core/src/index.ts",
    "../core/src/types.ts",
    "../core/src/track.ts",
    "../core/src/utils/format.ts",
    "../core/src/lyrics/parser.ts"
  ]
}
