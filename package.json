{
  "name": "music-player",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/gui",
    "packages/cli"
  ],
  "scripts": {
    "test": "bun test",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "build:core": "cd packages/core && bun run build",
    "dev:cli": "bun run packages/cli/src/main.ts",
    "build:cli:linux": "bun build --compile --target=bun-linux-x64-modern packages/cli/src/main.ts --outfile dist/MusicPlayer-cli-linux",
    "build:cli:windows": "bun build --compile --target=bun-windows-x64-modern packages/cli/src/main.ts --outfile dist/MusicPlayer-cli-windows",
    "dev:gui": "cd packages/gui && bun run tauri dev",
    "build:gui:linux": "cd packages/gui && bun run tauri build --target x86_64-unknown-linux-gnu",
    "build:gui:windows": "cd packages/gui && bun run tauri build --target x86_64-pc-windows-msvc"
  }
}
